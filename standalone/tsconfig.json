{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "../src/*": ["../src/*"]
    }
  },
  "include": ["src/**/*.ts", "../src/**/*.ts"]
}
